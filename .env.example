# ============================================================
# REQUIRED: Google Gemini API Key
# Get yours FREE at: https://aistudio.google.com/apikey
# Without this key the app runs in MOCK/DEMO mode (no real AI).
# ============================================================
GEMINI_API_KEY=your-gemini-api-key-here

# Database URL (defaults to SQLite for local dev)
DATABASE_URL=sqlite:///./rayeva.db

# App Config
DEBUG=false
APP_NAME=Rayeva AI Systems
