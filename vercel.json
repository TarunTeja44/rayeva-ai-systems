{
  "version": 2,
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  },
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "APP_NAME": "Rayeva AI Systems",
    "DEBUG": "false",
    "DATABASE_URL": "sqlite:///./rayeva.db"
  }
}
